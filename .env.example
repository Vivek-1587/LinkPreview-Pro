# ─── LinkPreview Pro — Environment Template ────────────────────────────────────
# Copy this file to .env and fill in your values.
# DO NOT commit .env — it is in .gitignore

# ─── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite file path.  Railway: set to "file:/app/data/prod.db" + volume mount
DATABASE_URL="file:./dev.db"


# ─── Email Provider ────────────────────────────────────────────────────────────
# Choose: smtp | resend | sendgrid
# Auto-detected from available keys if not set.
EMAIL_PROVIDER=

# ─── SMTP (Nodemailer) ─────────────────────────────────────────────────────────
# Gmail:    host=smtp.gmail.com  port=587  user=you@gmail.com  pass=<App Password>
# Resend:   host=smtp.resend.com port=587  user=resend          pass=re_xxxx
# Mailtrap: host=sandbox.smtp.mailtrap.io port=2525
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="LinkPreview Pro" <noreply@yourdomain.com>

# ─── Resend REST API ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── SendGrid REST API ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ─── JWT Secret ───────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret

# ─── Node Environment ─────────────────────────────────────────────────────────
# development = OTP printed to console if no email provider
# production  = strict email delivery required
NODE_ENV=development

# ─── Server Port (optional) ───────────────────────────────────────────────────
# PORT=3001
