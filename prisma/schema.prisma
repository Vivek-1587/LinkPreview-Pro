generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())

  previews    Preview[]
  collections Collection[]
  apiKeys     ApiKey[]
}

model Preview {
  id          String   @id @default(cuid())
  url         String
  domain      String
  title       String?
  description String?
  ogImage     String?
  favicon     String?
  status      String   @default("Success")
  createdAt   DateTime @default(now())

  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id])
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  previews Preview[]
}

model ApiKey {
  id           String    @id @default(cuid())
  name         String
  key          String    @unique
  maskedKey    String    @default("")
  requestCount Int       @default(0)
  lastUsedAt   DateTime?
  createdAt    DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResetToken {
  id        String   @id @default(cuid())
  email     String   @unique
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

